# Doxyfile for xml.c API documentation (configured by CMake)
# Generate with: cmake --build build --target api_docs

PROJECT_NAME		= "xml.c"
PROJECT_BRIEF		= "Lightweight XML parser in C"
INPUT			= @CMAKE_SOURCE_DIR@/src
FILE_PATTERNS		= *.c *.h
RECURSIVE		= NO
OUTPUT_DIRECTORY		= @CMAKE_BINARY_DIR@/api_docs
GENERATE_HTML		= YES
GENERATE_XML		= YES
GENERATE_LATEX		= NO
EXTRACT_ALL		= YES
EXTRACT_STATIC		= YES
SOURCE_BROWSER		= YES
INLINE_SOURCES		= NO
REFERENCED_BY_RELATION	= YES
REFERENCES_RELATION	= YES
OPTIMIZE_OUTPUT_FOR_C	= YES
QUIET			= YES
